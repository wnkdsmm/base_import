# ============================================================
# Настройки подключения к базе данных
# Скопируй этот файл в .env и заполни своими значениями
# ============================================================

# Строка подключения к PostgreSQL
# Формат: postgresql://пользователь:пароль@хост:порт/имя_базы
DATABASE_URL=postgresql://postgres:1234@localhost:5432/fires

# ============================================================
# Параметры сервера (менять не обязательно)
# ============================================================
APP_HOST=127.0.0.1
APP_PORT=8000
